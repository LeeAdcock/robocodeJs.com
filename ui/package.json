{
  "name": "@robocodejs/ui",
  "version": "0.1.0",
  "description": "RobocodeJs web front end — the React + Vite single-page app that renders the arena and the bot editor.",
  "author": "Lee Adcock <lee@robocodejs.com>",
  "license": "MIT",
  "private": true,
  "type": "module",
  "dependencies": {
    "@testing-library/user-event": "^14.6.1",
    "ace-builds": "^1.13.2",
    "axios": "^1.2.1",
    "bootstrap": "^5.3.8",
    "html-react-parser": "^6.1.4",
    "react": "^19.2.7",
    "react-ace": "^14.0.1",
    "react-bootstrap": "^2.10.10",
    "react-dom": "^19.2.7",
    "react-icons": "^5.7.0",
    "react-router-dom": "^7.18.1",
    "showdown": "^2.1.0"
  },
  "scripts": {
    "dev": "fuser -k 3000/tcp & vite",
    "start": "fuser -k 3000/tcp & vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview --port 3000",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src --fix ; prettier --write src test",
    "lint:eslint": "eslint src --fix"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/showdown": "^2.0.6",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^10.7.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.9.5",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.64.0",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  }
}
