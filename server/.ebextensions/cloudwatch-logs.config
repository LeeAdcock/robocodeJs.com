# Stream the instance logs (including the app's stdout, where the structured pino
# JSON is written) to CloudWatch Logs, so they are queryable in Logs Insights and
# can back the metric-filter alarms in cloudwatch-alarms.config. Without this,
# stdout only lands in the instance's rotated logs (EB "Request logs"), with no
# log group to alarm on.
#
# This creates a log group named:
#   /aws/elasticbeanstalk/<env-name>/var/log/web.stdout.log
# e.g. /aws/elasticbeanstalk/robocode-prod/var/log/web.stdout.log
#
# Cost note: log ingestion + storage is billed; RetentionInDays bounds storage.
option_settings:
  aws:elasticbeanstalk:cloudwatch:logs:
    StreamLogs: true
    DeleteOnTerminate: false
    RetentionInDays: 30
