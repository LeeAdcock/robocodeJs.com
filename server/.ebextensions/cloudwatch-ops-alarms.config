# Availability / infrastructure / reliability CloudWatch alarms.
#
# Companion to cloudwatch-alarms.config (which covers the app's security/bot
# *log* events). This file adds the "is it broken?" signals that log events
# alone can't see — the load balancer, the RDS database, the EC2 host, and two
# more reliability log events. Everything notifies the same target.
#
# ── Notification target ───────────────────────────────────────────────────────
# All alarms publish to the account SNS topic `Alerts` (a confirmed email
# subscription), overridable per environment via the env property
# ALERT_SNS_TOPIC_ARN. The two log-metric filters read ALERT_LOG_GROUP (same
# defaults as cloudwatch-alarms.config).
#
# ── Resource references ───────────────────────────────────────────────────────
# The RDS/ALB/EC2 alarms reference the resources Elastic Beanstalk creates in
# this environment's own CloudFormation stack (confirmed logical IDs, us-east-1
# env robocode-prod): AWSEBRDSDatabase (db.t3.micro, 5 GB Postgres),
# AWSEBV2LoadBalancer + AWSEBV2LoadBalancerTargetGroup (the ALB), and
# AWSEBAutoScalingGroup (the t2.micro host). Thresholds are starting points —
# tune once you have a baseline.
#
# Host MEMORY is deliberately NOT here: the app's `event=metrics` heartbeat
# (rssMB) is emitted as syslog-prefixed JSON, which a CloudWatch metric filter
# can't parse numerically, so host memory needs the CloudWatch agent + an
# instance-role IAM grant. That is documented as a follow-up in ops/README.md;
# meanwhile EC2 CPU / CPU-credit, RDS FreeableMemory, and the process.fatal
# alarm give strong indirect coverage.

Resources:
  # ── Load balancer / availability ───────────────────────────────────────────

  # No healthy targets behind the ALB — the site is effectively DOWN. This is the
  # signal the log-event alarms can't give (they go quiet when the app is down).
  AlbUnhealthyHostsAlarm:
    Type: 'AWS::CloudWatch::Alarm'
    Properties:
      AlarmName: 'robocodejs-alb-unhealthy-hosts'
      AlarmDescription: 'One or more instances are failing ALB health checks (possible outage).'
      Namespace: 'AWS/ApplicationELB'
      MetricName: 'UnHealthyHostCount'
      Dimensions:
        - Name: 'LoadBalancer'
          Value:
            'Fn::GetAtt': ['AWSEBV2LoadBalancer', 'LoadBalancerFullName']
        - Name: 'TargetGroup'
          Value:
            'Fn::GetAtt': ['AWSEBV2LoadBalancerTargetGroup', 'TargetGroupFullName']
      Statistic: Maximum
      Period: 60
      EvaluationPeriods: 3
      Threshold: 1
      ComparisonOperator: GreaterThanOrEqualToThreshold
      TreatMissingData: notBreaching
      AlarmActions:
        - 'Fn::GetOptionSetting':
            Namespace: 'aws:elasticbeanstalk:application:environment'
            OptionName: 'ALERT_SNS_TOPIC_ARN'
            DefaultValue: 'arn:aws:sns:us-east-1:095207682014:Alerts'

  # Load-balancer-generated 5xx (502/503/504) — no healthy target, timeouts, etc.
  AlbElb5xxAlarm:
    Type: 'AWS::CloudWatch::Alarm'
    Properties:
      AlarmName: 'robocodejs-alb-elb-5xx'
      AlarmDescription: 'ALB is returning 5xx (no healthy target / timeouts).'
      Namespace: 'AWS/ApplicationELB'
      MetricName: 'HTTPCode_ELB_5XX_Count'
      Dimensions:
        - Name: 'LoadBalancer'
          Value:
            'Fn::GetAtt': ['AWSEBV2LoadBalancer', 'LoadBalancerFullName']
      Statistic: Sum
      Period: 300
      EvaluationPeriods: 1
      Threshold: 5
      ComparisonOperator: GreaterThanOrEqualToThreshold
      TreatMissingData: notBreaching
      AlarmActions:
        - 'Fn::GetOptionSetting':
            Namespace: 'aws:elasticbeanstalk:application:environment'
            OptionName: 'ALERT_SNS_TOPIC_ARN'
            DefaultValue: 'arn:aws:sns:us-east-1:095207682014:Alerts'

  # Application 5xx served through the ALB — the app itself erroring at volume.
  AlbTarget5xxAlarm:
    Type: 'AWS::CloudWatch::Alarm'
    Properties:
      AlarmName: 'robocodejs-alb-target-5xx'
      AlarmDescription: 'The app is returning 5xx responses at volume (event-independent).'
      Namespace: 'AWS/ApplicationELB'
      MetricName: 'HTTPCode_Target_5XX_Count'
      Dimensions:
        - Name: 'LoadBalancer'
          Value:
            'Fn::GetAtt': ['AWSEBV2LoadBalancer', 'LoadBalancerFullName']
        - Name: 'TargetGroup'
          Value:
            'Fn::GetAtt': ['AWSEBV2LoadBalancerTargetGroup', 'TargetGroupFullName']
      Statistic: Sum
      Period: 300
      EvaluationPeriods: 1
      Threshold: 10
      ComparisonOperator: GreaterThanOrEqualToThreshold
      TreatMissingData: notBreaching
      AlarmActions:
        - 'Fn::GetOptionSetting':
            Namespace: 'aws:elasticbeanstalk:application:environment'
            OptionName: 'ALERT_SNS_TOPIC_ARN'
            DefaultValue: 'arn:aws:sns:us-east-1:095207682014:Alerts'

  # ── RDS Postgres (db.t3.micro, 5 GB) ───────────────────────────────────────

  # Free storage low — the single most likely DB outage on a 5 GB disk.
  RdsFreeStorageAlarm:
    Type: 'AWS::CloudWatch::Alarm'
    Properties:
      AlarmName: 'robocodejs-rds-free-storage'
      AlarmDescription: 'RDS free storage below 512 MB (of 5 GB) — risk of a full disk.'
      Namespace: 'AWS/RDS'
      MetricName: 'FreeStorageSpace'
      Dimensions:
        - Name: 'DBInstanceIdentifier'
          Value:
            Ref: 'AWSEBRDSDatabase'
      Statistic: Minimum
      Period: 300
      EvaluationPeriods: 1
      Threshold: 536870912 # 512 MiB in bytes
      ComparisonOperator: LessThanOrEqualToThreshold
      TreatMissingData: notBreaching
      AlarmActions:
        - 'Fn::GetOptionSetting':
            Namespace: 'aws:elasticbeanstalk:application:environment'
            OptionName: 'ALERT_SNS_TOPIC_ARN'
            DefaultValue: 'arn:aws:sns:us-east-1:095207682014:Alerts'

  RdsCpuAlarm:
    Type: 'AWS::CloudWatch::Alarm'
    Properties:
      AlarmName: 'robocodejs-rds-cpu'
      AlarmDescription: 'RDS CPU above 85% for 15 min.'
      Namespace: 'AWS/RDS'
      MetricName: 'CPUUtilization'
      Dimensions:
        - Name: 'DBInstanceIdentifier'
          Value:
            Ref: 'AWSEBRDSDatabase'
      Statistic: Average
      Period: 300
      EvaluationPeriods: 3
      Threshold: 85
      ComparisonOperator: GreaterThanThreshold
      TreatMissingData: notBreaching
      AlarmActions:
        - 'Fn::GetOptionSetting':
            Namespace: 'aws:elasticbeanstalk:application:environment'
            OptionName: 'ALERT_SNS_TOPIC_ARN'
            DefaultValue: 'arn:aws:sns:us-east-1:095207682014:Alerts'

  # ~112 max_connections on db.t3.micro; 80 is a sustained-pressure warning.
  RdsConnectionsAlarm:
    Type: 'AWS::CloudWatch::Alarm'
    Properties:
      AlarmName: 'robocodejs-rds-connections'
      AlarmDescription: 'RDS connections sustained high (approaching the db.t3.micro cap).'
      Namespace: 'AWS/RDS'
      MetricName: 'DatabaseConnections'
      Dimensions:
        - Name: 'DBInstanceIdentifier'
          Value:
            Ref: 'AWSEBRDSDatabase'
      Statistic: Average
      Period: 300
      EvaluationPeriods: 3
      Threshold: 80
      ComparisonOperator: GreaterThanThreshold
      TreatMissingData: notBreaching
      AlarmActions:
        - 'Fn::GetOptionSetting':
            Namespace: 'aws:elasticbeanstalk:application:environment'
            OptionName: 'ALERT_SNS_TOPIC_ARN'
            DefaultValue: 'arn:aws:sns:us-east-1:095207682014:Alerts'

  RdsFreeableMemoryAlarm:
    Type: 'AWS::CloudWatch::Alarm'
    Properties:
      AlarmName: 'robocodejs-rds-freeable-memory'
      AlarmDescription: 'RDS freeable memory below 100 MB — memory pressure on the DB.'
      Namespace: 'AWS/RDS'
      MetricName: 'FreeableMemory'
      Dimensions:
        - Name: 'DBInstanceIdentifier'
          Value:
            Ref: 'AWSEBRDSDatabase'
      Statistic: Average
      Period: 300
      EvaluationPeriods: 3
      Threshold: 104857600 # 100 MiB in bytes
      ComparisonOperator: LessThanThreshold
      TreatMissingData: notBreaching
      AlarmActions:
        - 'Fn::GetOptionSetting':
            Namespace: 'aws:elasticbeanstalk:application:environment'
            OptionName: 'ALERT_SNS_TOPIC_ARN'
            DefaultValue: 'arn:aws:sns:us-east-1:095207682014:Alerts'

  # ── EC2 host (t2.micro) ─────────────────────────────────────────────────────

  Ec2CpuAlarm:
    Type: 'AWS::CloudWatch::Alarm'
    Properties:
      AlarmName: 'robocodejs-ec2-cpu'
      AlarmDescription: 'Instance CPU above 85% for 15 min (also an indirect memory/swap-thrash signal).'
      Namespace: 'AWS/EC2'
      MetricName: 'CPUUtilization'
      Dimensions:
        - Name: 'AutoScalingGroupName'
          Value:
            Ref: 'AWSEBAutoScalingGroup'
      Statistic: Average
      Period: 300
      EvaluationPeriods: 3
      Threshold: 85
      ComparisonOperator: GreaterThanThreshold
      TreatMissingData: notBreaching
      AlarmActions:
        - 'Fn::GetOptionSetting':
            Namespace: 'aws:elasticbeanstalk:application:environment'
            OptionName: 'ALERT_SNS_TOPIC_ARN'
            DefaultValue: 'arn:aws:sns:us-east-1:095207682014:Alerts'

  # t2 burstable credits — if these run out the instance is throttled hard.
  # Requires 30 minutes sustained (6-of-6 5-min datapoints): every Immutable
  # deploy briefly dips the ASG-average balance (the fresh instance starts on
  # small launch credits), so a single-datapoint alarm paged on each deploy. A
  # genuine drain — steady load above the t2 baseline — breaches far longer.
  Ec2CpuCreditsAlarm:
    Type: 'AWS::CloudWatch::Alarm'
    Properties:
      AlarmName: 'robocodejs-ec2-cpu-credits'
      AlarmDescription: 'EC2 CPU credit balance low for 30+ min — the t2.micro is being throttled.'
      Namespace: 'AWS/EC2'
      MetricName: 'CPUCreditBalance'
      Dimensions:
        - Name: 'AutoScalingGroupName'
          Value:
            Ref: 'AWSEBAutoScalingGroup'
      Statistic: Average
      Period: 300
      EvaluationPeriods: 6
      DatapointsToAlarm: 6
      Threshold: 20
      ComparisonOperator: LessThanThreshold
      TreatMissingData: notBreaching
      AlarmActions:
        - 'Fn::GetOptionSetting':
            Namespace: 'aws:elasticbeanstalk:application:environment'
            OptionName: 'ALERT_SNS_TOPIC_ARN'
            DefaultValue: 'arn:aws:sns:us-east-1:095207682014:Alerts'

  # ── Reliability log events (same mechanism as cloudwatch-alarms.config) ──────

  # event="db.error" — a Postgres query/connection error surfaced by the app.
  DbErrorMetricFilter:
    Type: 'AWS::Logs::MetricFilter'
    Properties:
      LogGroupName:
        'Fn::GetOptionSetting':
          Namespace: 'aws:elasticbeanstalk:application:environment'
          OptionName: 'ALERT_LOG_GROUP'
          DefaultValue: '/aws/elasticbeanstalk/robocode-prod/var/log/web.stdout.log'
      FilterPattern: '"\"event\":\"db.error\""'
      MetricTransformations:
        - MetricNamespace: 'RobocodeJs/App'
          MetricName: 'DbError'
          MetricValue: '1'
          DefaultValue: 0
  DbErrorAlarm:
    Type: 'AWS::CloudWatch::Alarm'
    Properties:
      AlarmName: 'robocodejs-db-error'
      AlarmDescription: 'Database errors from the app (event=db.error).'
      Namespace: 'RobocodeJs/App'
      MetricName: 'DbError'
      Statistic: Sum
      Period: 300
      EvaluationPeriods: 1
      Threshold: 3
      ComparisonOperator: GreaterThanOrEqualToThreshold
      TreatMissingData: notBreaching
      AlarmActions:
        - 'Fn::GetOptionSetting':
            Namespace: 'aws:elasticbeanstalk:application:environment'
            OptionName: 'ALERT_SNS_TOPIC_ARN'
            DefaultValue: 'arn:aws:sns:us-east-1:095207682014:Alerts'

  # event="http.error" — an unhandled 5xx surfaced by the Express error handler.
  HttpErrorMetricFilter:
    Type: 'AWS::Logs::MetricFilter'
    Properties:
      LogGroupName:
        'Fn::GetOptionSetting':
          Namespace: 'aws:elasticbeanstalk:application:environment'
          OptionName: 'ALERT_LOG_GROUP'
          DefaultValue: '/aws/elasticbeanstalk/robocode-prod/var/log/web.stdout.log'
      FilterPattern: '"\"event\":\"http.error\""'
      MetricTransformations:
        - MetricNamespace: 'RobocodeJs/App'
          MetricName: 'HttpError'
          MetricValue: '1'
          DefaultValue: 0
  HttpErrorAlarm:
    Type: 'AWS::CloudWatch::Alarm'
    Properties:
      AlarmName: 'robocodejs-http-error'
      AlarmDescription: 'Server-side 5xx errors from the app (event=http.error).'
      Namespace: 'RobocodeJs/App'
      MetricName: 'HttpError'
      Statistic: Sum
      Period: 300
      EvaluationPeriods: 1
      Threshold: 10
      ComparisonOperator: GreaterThanOrEqualToThreshold
      TreatMissingData: notBreaching
      AlarmActions:
        - 'Fn::GetOptionSetting':
            Namespace: 'aws:elasticbeanstalk:application:environment'
            OptionName: 'ALERT_SNS_TOPIC_ARN'
            DefaultValue: 'arn:aws:sns:us-east-1:095207682014:Alerts'
