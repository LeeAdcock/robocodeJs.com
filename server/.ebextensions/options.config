packages: 
  yum:
    gcc: []
    gcc-c++: []
    
option_settings:
  aws:elasticbeanstalk:application:environment:
    AWS_REGION: '`{"Ref" : "AWS::Region"}`'
    NODE_ENV: production
    # Wall-clock ceiling (ms) for a single synchronous entry into untrusted bot
    # code — one event handler, timer callback, command settlement, or the
    # top-level script load (compiler.ts sandboxTimeoutMs, default 5000). It's an
    # infinite-loop backstop, not a work budget: a legitimate handler finishes in
    # well under a millisecond, so lowering it shrinks the window a runaway bot
    # can freeze its arena (and, since host callbacks serialize on the main
    # isolate, degrade the shared box) from ~5s to ~1s. Watch the
    # bot.fault/timedOut CloudWatch alarm after this change; if legitimately
    # compute-heavy bots start tripping it, raise it back toward 5000.
    SANDBOX_TIMEOUT_MS: '1000'
    # Start the global bot ladder — the background matchmaking loop that runs
    # ranked matches between eligible apps and adjusts their Elo, feeding the
    # public /leaderboard (GitHub #151, src/services/LadderService.ts). It's
    # opt-in because it's real, continuous isolate compute; without this the
    # leaderboard stays empty. Pinned here (not just an EB console property) so
    # it survives an environment recreate. The LADDER_* tuning knobs are left at
    # their conservative defaults (1 worker, load-gated off live-isolate count),
    # which suit the small prod instance.
    LADDER_ENABLED: 'true'
  aws:elasticbeanstalk:container:nodejs:
    ProxyServer: nginx
  # Zero-downtime deploys on this single-instance, load-balanced env. Immutable
  # launches ONE fresh instance in a temporary ASG, provisions + boots the new
  # version there while the old instance keeps serving all traffic, waits for it
  # to pass health checks, then swaps it into the main ASG and terminates the old
  # one. Replaces the previous AllAtOnce policy, which redeployed in place on the
  # single instance and briefly 502'd during the swap. Also safer: a new version
  # that fails health checks is discarded and the old instance never stops serving
  # (AllAtOnce would take prod down on a bad deploy). Costs one extra instance for
  # the ~10-15 min deploy window; ASG MaxSize (4) has room. The change itself
  # takes effect from the NEXT deploy — the deploy that introduces it still runs
  # under the old policy.
  aws:elasticbeanstalk:command:
    DeploymentPolicy: Immutable
  # Gate the Immutable swap on the real app, not the static SPA. The default ALB
  # health check hit `/`, which serves index.html and returns 200 even if the API
  # or DB is down — so a broken backend could pass the swap gate and get promoted.
  # `/health` exercises the server (and reports the running version), so an
  # unhealthy new instance is caught and the cutover is blocked.
  aws:elasticbeanstalk:environment:process:default:
    HealthCheckPath: /health
  # Don't let 4xx responses degrade enhanced health. At this site's overnight
  # traffic (a few requests/minute), two or three scanner 404s can be 60-100%
  # of a health window's sample, flapping the environment Ok<->Warning and
  # emailing every transition — EB itself flags these as "Insufficient request
  # rate". Real signal is unaffected: the 5xx, latency, and instance-level
  # health rules stay on, and the robocodejs-alb-* alarms watch 5xx directly.
  # Precedence caveat: a ConfigDocument set directly on the environment
  # (console/API) shadows this file; if the rules are still enabled after a
  # deploy, clear it once with
  # `aws elasticbeanstalk update-environment --environment-name robocode-prod
  #  --options-to-remove Namespace=aws:elasticbeanstalk:healthreporting:system,OptionName=ConfigDocument`.
  aws:elasticbeanstalk:healthreporting:system:
    ConfigDocument: '{"Version":1,"Rules":{"Environment":{"ELB":{"ELBRequests4xx":{"Enabled":false}},"Application":{"ApplicationRequests4xx":{"Enabled":false}}}}}'
  aws:elbv2:listener:443:
    ListenerEnabled: 'true'
    Protocol: HTTPS
    SSLCertificateArns: arn:aws:acm:us-east-1:095207682014:certificate/e0721a75-2b5c-42b9-ba36-7416da98bad9
  aws:rds:dbinstance:
    DBAllocatedStorage: 5
  # Email Elastic Beanstalk's own environment events (deploy failures,
  # environment health -> Degraded/Severe, instance add/replace) to the same
  # confirmed inbox the CloudWatch alarms use. Without this, EB env events only
  # show in the console.
  aws:elasticbeanstalk:sns:topics:
    Notification Topic ARN: arn:aws:sns:us-east-1:095207682014:Alerts