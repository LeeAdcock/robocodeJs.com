# Give the 1 GB t2.micro headroom during deploys. The .ebextensions `yum` step
# (installing gcc/gcc-c++ for the isolated-vm native build) plus the still-running
# previous app version can exceed 1 GB of RAM, and the kernel OOM-kills `yum`
# (exit -9), failing the deploy. A swapfile lets idle pages spill to the existing
# root volume (no extra cost, stays in free tier). Idempotent and persisted via
# /etc/fstab, so once established it stays active across deploys and reboots.
#
# NOTE: .ebextensions `commands` run AFTER the `yum` packages phase, so this can't
# rescue the very first deploy on an instance that is already OOM-ing (the app is
# already running there). Establish swap once out-of-band on that instance; from
# then on this keeps it in place, including for any replacement instance (whose
# first deploy has no competing app and so has room for yum anyway).
commands:
  01_create_swapfile:
    command: |
      set -e
      SWAPFILE=/var/swapfile
      if ! swapon --show=NAME --noheadings | grep -qx "$SWAPFILE"; then
        if [ ! -f "$SWAPFILE" ]; then
          dd if=/dev/zero of="$SWAPFILE" bs=1M count=1024
          chmod 600 "$SWAPFILE"
          mkswap "$SWAPFILE"
        fi
        swapon "$SWAPFILE"
      fi
      if ! grep -q "$SWAPFILE" /etc/fstab; then
        echo "$SWAPFILE swap swap defaults 0 0" >> /etc/fstab
      fi
