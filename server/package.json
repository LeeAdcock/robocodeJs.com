{
  "name": "@battletank/server",
  "version": "1.2.45",
  "description": "",
  "main": "./dist/src/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "fuser -k 8080/tcp & nodemon --watch src -e ts,ejs --exec npm run dev:start",
    "dev:start": "npm-run-all build start",
    "lint": "npx prettier --write src && npx eslint src --fix",
    "start": "node ./dist/src/index.js",
    "smoke": "node ./scripts/ivm-smoke.js",
    "test": "echo \"Error: no test specified\" && exit 1",
    "package": "npm version patch && npm shrinkwrap && zip -r robocodejs-${npm_package_version}.zip ./ -x '*src*' -x '*.git' -x '*robocodejs*zip*' -x '*artifact.zip*' -x '*node_modules*'"
  },
  "author": "",
  "license": "ISC",
  "dependencies": {
    "browser-bunyan": "^1.8.0",
    "cookie-parser": "^1.4.6",
    "express": "^4.18.2",
    "google-auth-library": "^8.7.0",
    "isolated-vm": "^6.1.2",
    "ml-classify-text": "^2.0.0",
    "pg": "^8.8.0",
    "uuid": "^11.1.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.14",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.6.6",
    "@typescript-eslint/eslint-plugin": "^5.48.1",
    "@typescript-eslint/parser": "^5.48.1",
    "eslint": "^8.31.0",
    "nodemon": "^3.1.14",
    "npm-run-all": "^4.1.5",
    "prettier": "2.8.3",
    "typescript": "^4.9.3"
  },
  "engines": {
    "npm": ">=10.0.0",
    "node": ">=22.0.0"
  }
}
