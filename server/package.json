{
  "name": "@robocodejs/server",
  "version": "1.2.96",
  "description": "RobocodeJs API server and game-simulation engine — an Express + TypeScript API with the isolated-vm bot sandbox.",
  "main": "./dist/src/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "fuser -k 8080/tcp & nodemon --watch src -e ts,ejs --exec npm run dev:start",
    "dev:start": "npm-run-all build start",
    "lint": "npx prettier --write src test && npx eslint src --fix",
    "lint:eslint": "eslint src --fix",
    "start": "node ./dist/src/index.js",
    "smoke": "node ./scripts/ivm-smoke.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "release": "npm version patch --no-git-tag-version && npm shrinkwrap",
    "bundle": "zip -r robocodejs-$(node -p \"require('./package.json').version\").zip ./ -x 'src/*' -x 'test/*' -x 'coverage/*' -x '*.git' -x '*robocodejs*zip*' -x '*artifact.zip*' -x '*node_modules*'"
  },
  "author": "Lee Adcock <lee@robocodejs.com>",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "browser-bunyan": "^1.8.0",
    "cookie-parser": "^1.4.6",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "glin-profanity": "^3.3.0",
    "google-auth-library": "^10.9.0",
    "helmet": "^8.3.0",
    "isolated-vm": "^6.1.2",
    "ml-classify-text": "^2.0.1",
    "pg": "^8.22.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "prettier": "^3.9.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/cookie-parser": "^1.4.7",
    "@types/express": "^5.0.6",
    "@types/node": "^24.13.2",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^10.7.0",
    "globals": "^17.7.0",
    "nodemon": "^3.1.14",
    "npm-run-all": "^4.1.5",
    "pg-mem": "^3.0.14",
    "pino-pretty": "^13.1.3",
    "supertest": "^7.1.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.63.0",
    "vitest": "^4.1.10"
  },
  "engines": {
    "npm": ">=10.0.0"
  }
}
